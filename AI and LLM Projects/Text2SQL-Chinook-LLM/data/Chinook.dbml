Table Album {
  AlbumId INTEGER [pk]
  Title NVARCHAR(160)
  ArtistId INTEGER
}

Ref: Album.ArtistId > Artist.ArtistId

Table Artist {
  ArtistId INTEGER [pk]
  Name NVARCHAR(120)
}

Table Customer {
  CustomerId INTEGER [pk]
  FirstName NVARCHAR(40)
  LastName NVARCHAR(20)
  Company NVARCHAR(80)
  Address NVARCHAR(70)
  City NVARCHAR(40)
  State NVARCHAR(40)
  Country NVARCHAR(40)
  PostalCode NVARCHAR(10)
  Phone NVARCHAR(24)
  Fax NVARCHAR(24)
  Email NVARCHAR(60)
  SupportRepId INTEGER
}

Ref: Customer.SupportRepId > Employee.EmployeeId

Table Employee {
  EmployeeId INTEGER [pk]
  LastName NVARCHAR(20)
  FirstName NVARCHAR(20)
  Title NVARCHAR(30)
  ReportsTo INTEGER
  BirthDate DATETIME
  HireDate DATETIME
  Address NVARCHAR(70)
  City NVARCHAR(40)
  State NVARCHAR(40)
  Country NVARCHAR(40)
  PostalCode NVARCHAR(10)
  Phone NVARCHAR(24)
  Fax NVARCHAR(24)
  Email NVARCHAR(60)
}

Ref: Employee.ReportsTo > Employee.EmployeeId

Table Genre {
  GenreId INTEGER [pk]
  Name NVARCHAR(120)
}

Table Invoice {
  InvoiceId INTEGER [pk]
  CustomerId INTEGER
  InvoiceDate DATETIME
  BillingAddress NVARCHAR(70)
  BillingCity NVARCHAR(40)
  BillingState NVARCHAR(40)
  BillingCountry NVARCHAR(40)
  BillingPostalCode NVARCHAR(10)
  Total NUMERIC(10,2)
}

Ref: Invoice.CustomerId > Customer.CustomerId

Table InvoiceLine {
  InvoiceLineId INTEGER [pk]
  InvoiceId INTEGER
  TrackId INTEGER
  UnitPrice NUMERIC(10,2)
  Quantity INTEGER
}

Ref: InvoiceLine.TrackId > Track.TrackId

Ref: InvoiceLine.InvoiceId > Invoice.InvoiceId

Table MediaType {
  MediaTypeId INTEGER [pk]
  Name NVARCHAR(120)
}

Table Playlist {
  PlaylistId INTEGER [pk]
  Name NVARCHAR(120)
}

Table PlaylistTrack {
  PlaylistId INTEGER [pk]
  TrackId INTEGER [pk]
}

Ref: PlaylistTrack.TrackId > Track.TrackId

Ref: PlaylistTrack.PlaylistId > Playlist.PlaylistId

Table Track {
  TrackId INTEGER [pk]
  Name NVARCHAR(200)
  AlbumId INTEGER
  MediaTypeId INTEGER
  GenreId INTEGER
  Composer NVARCHAR(220)
  Milliseconds INTEGER
  Bytes INTEGER
  UnitPrice NUMERIC(10,2)
}

Ref: Track.MediaTypeId > MediaType.MediaTypeId

Ref: Track.GenreId > Genre.GenreId

Ref: Track.AlbumId > Album.AlbumId
